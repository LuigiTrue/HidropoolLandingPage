@page "/"
@using Microsoft.AspNetCore.Components

<PageTitle>Hidropool Araxá – Transforme Sua Área de Lazer</PageTitle>

<div class="hp-root">

    <!-- ===== NAVBAR ===== -->
    <nav class="hp-nav">
        <div class="hp-nav__inner">
            <a href="/" class="hp-nav__logo">
                <img src="https://cdn.landingpage.app.br/piscinas.hidropoolaraxa.com.br-transforme-sua/1751924785/imagens/desktop/1673693_1_174170112863178897.png"
                     alt="Hidropool Araxá" class="hp-nav__logo-img" />
            </a>
            <a class="hp-nav__cta" href="#orcamento">Orçamento Grátis</a>
        </div>
    </nav>

    <!-- ===== HERO ===== -->
    <section class="hp-hero">
        <div class="hp-hero__bg">
            <div class="hp-hero__wave hp-hero__wave--1"></div>
            <div class="hp-hero__wave hp-hero__wave--2"></div>
            <div class="hp-hero__bubbles">
                @for (int i = 0; i < 12; i++)
                {
                    <span class="hp-bubble" style="--d:@(i * 0.4)s;--x:@(i * 8 + 4)%;--s:@(10 + i * 4)px"></span>
                }
            </div>
        </div>
        <div class="hp-hero__content">
            <p class="hp-hero__eyebrow">Especialistas em Piscinas · Araxá, MG</p>
            <h1 class="hp-hero__title">
                Transforme Sua<br>
                <span class="hp-hero__title--accent">Área de Lazer</span><br>
                em um Paraíso
            </h1>
            <p class="hp-hero__sub">
                Piscinas de <strong>vinil</strong> e <strong>azulejo</strong>, aquecimento solar,
                spa, sauna e hidromassagem com o padrão que Araxá merece.
            </p>
            <div class="hp-hero__actions">
                <a href="#orcamento" class="hp-btn hp-btn--primary">Quero Minha Piscina 🏊</a>
                <a href="https://wa.me/5534999999999" target="_blank" class="hp-btn hp-btn--ghost">
                    Falar no WhatsApp
                </a>
            </div>
            <div class="hp-hero__badges">
                <span class="hp-badge">✅ Projeto Incluso</span>
                <span class="hp-badge">✅ Garantia</span>
                <span class="hp-badge">✅ Equipe Especializada</span>
            </div>
        </div>
        <div class="hp-hero__scroll-hint">
            <span></span>
        </div>
    </section>

    <!-- ===== NÚMEROS ===== -->
    <section class="hp-stats">
        <div class="hp-stats__inner">
            <div class="hp-stat">
                <span class="hp-stat__num">+500</span>
                <span class="hp-stat__lbl">Piscinas Entregues</span>
            </div>
            <div class="hp-stat">
                <span class="hp-stat__num">100%</span>
                <span class="hp-stat__lbl">Satisfação Garantida</span>
            </div>
            <div class="hp-stat">
                <span class="hp-stat__num">15+</span>
                <span class="hp-stat__lbl">Anos de Expertise</span>
            </div>
            <div class="hp-stat">
                <span class="hp-stat__num">24h</span>
                <span class="hp-stat__lbl">Suporte Pós-Venda</span>
            </div>
        </div>
    </section>

    <!-- ===== SERVIÇOS ===== -->
    <section class="hp-services" id="servicos">
        <div class="hp-section-header">
            <span class="hp-section-tag">O que fazemos</span>
            <h2 class="hp-section-title">Soluções Completas<br>para Seu Lazer</h2>
        </div>
        <div class="hp-services__grid">
            <div class="hp-service-card hp-service-card--featured">
                <div class="hp-service-card__icon">🏊‍♂️</div>
                <h3>Piscinas de Vinil</h3>
                <p>Instalação rápida, design exclusivo e fácil manutenção. Disponíveis em infinitos tamanhos e formatos
                    para se adaptar ao seu espaço.</p>
                    <ul>
                        <li>Rápida instalação</li>
                        <li>Alta durabilidade</li>
                        <li>Fácil manutenção</li>
                        <li>Projeto personalizado</li>
                    </ul>
                </div>
                <div class="hp-service-card">
                    <div class="hp-service-card__icon">🔷</div>
                    <h3>Piscinas de Azulejo</h3>
                    <p>Beleza clássica e sofisticação que valoriza o seu imóvel. Revestimento premium com acabamento
                        impecável.</p>
                        <ul>
                            <li>Acabamento premium</li>
                            <li>Alta valorização</li>
                            <li>Versatilidade de design</li>
                            <li>Durabilidade superior</li>
                        </ul>
                    </div>
                    <div class="hp-service-card">
                        <div class="hp-service-card__icon">☀️</div>
                        <h3>Aquecimento Solar</h3>
                        <p>Aproveite sua piscina o ano inteiro com economia. Sistemas de aquecimento solar residenciais e
                            comerciais.</p>
                            <ul>
                                <li>Economia de energia</li>
                                <li>Uso o ano todo</li>
                                <li>Instalação residencial</li>
                                <li>Retorno garantido</li>
                            </ul>
                        </div>
                        <div class="hp-service-card">
                            <div class="hp-service-card__icon">💆</div>
                            <h3>Spa & Hidromassagem</h3>
                            <p>Relaxamento e bem-estar no conforto da sua casa. Banheiras de hidromassagem, spa, ofurô e sauna.</p>
                            <ul>
                                <li>Banheiras de hidromassagem</li>
                                <li>Spa e ofurô</li>
                                <li>Sauna a vapor</li>
                                <li>Instalação completa</li>
                            </ul>
                        </div>
                        <div class="hp-service-card">
                            <div class="hp-service-card__icon">💡</div>
                            <h3>Iluminação</h3>
                            <p>Transforme sua piscina em um espetáculo à noite. Iluminação LED subaquática e paisagismo luminoso.
                            </p>
                            <ul>
                                <li>LED subaquático</li>
                                <li>RGB multicolor</li>
                                <li>Economia de energia</li>
                                <li>Efeito cenográfico</li>
                            </ul>
                        </div>
                        <div class="hp-service-card">
                            <div class="hp-service-card__icon">🧴</div>
                            <h3>Produtos & Manutenção</h3>
                            <p>Tudo que sua piscina precisa para se manter cristalina. Produtos químicos, equipamentos e serviço de
                                manutenção periódica.</p>
                                <ul>
                                    <li>Produtos químicos</li>
                                    <li>Equipamentos filtragem</li>
                                    <li>Manutenção periódica</li>
                                    <li>Atendimento técnico</li>
                                </ul>
                            </div>
                        </div>
                    </section>

                    <!-- ===== COMO FUNCIONA ===== -->
                    <section class="hp-steps">
                        <div class="hp-section-header hp-section-header--light">
                            <span class="hp-section-tag">Simples assim</span>
                            <h2 class="hp-section-title">Como Funciona</h2>
                        </div>
                        <div class="hp-steps__track">
                            <div class="hp-step">
                                <div class="hp-step__num">01</div>
                                <div class="hp-step__body">
                                    <h3>Solicite seu Orçamento</h3>
                                    <p>Preencha o formulário ou entre em contato pelo WhatsApp. Rápido e sem compromisso.</p>
                                </div>
                            </div>
                            <div class="hp-step__connector"></div>
                            <div class="hp-step">
                                <div class="hp-step__num">02</div>
                                <div class="hp-step__body">
                                    <h3>Visita Técnica</h3>
                                    <p>Nossa equipe vai até você avaliar o espaço e apresentar as melhores soluções.</p>
                                </div>
                            </div>
                            <div class="hp-step__connector"></div>
                            <div class="hp-step">
                                <div class="hp-step__num">03</div>
                                <div class="hp-step__body">
                                    <h3>Projeto Personalizado</h3>
                                    <p>Criamos o projeto ideal para o seu espaço, gosto e orçamento, incluindo planta técnica.</p>
                                </div>
                            </div>
                            <div class="hp-step__connector"></div>
                            <div class="hp-step">
                                <div class="hp-step__num">04</div>
                                <div class="hp-step__body">
                                    <h3>Obra e Entrega</h3>
                                    <p>Execução com qualidade e no prazo combinado. Entregamos sua piscina pronta para curtir.</p>
                                </div>
                            </div>
                        </div>
                    </section>

                    <!-- ===== DEPOIMENTOS ===== -->
                    <section class="hp-testimonials">
                        <div class="hp-section-header">
                            <span class="hp-section-tag">Quem já curtiu</span>
                            <h2 class="hp-section-title">O que nossos clientes dizem</h2>
                        </div>
                        <div class="hp-testimonials__grid">
                            <div class="hp-testimonial">
                                <div class="hp-testimonial__stars">★★★★★</div>
                                <p>"Equipe super profissional, entregaram no prazo e a piscina ficou ainda mais bonita do que
                                    imaginávamos. Recomendo demais!"</p>
                                    <div class="hp-testimonial__author">
                                        <div class="hp-testimonial__avatar">MF</div>
                                        <div>
                                            <strong>Maria Fernanda</strong>
                                            <span>Araxá, MG</span>
                                        </div>
                                    </div>
                                </div>
                                <div class="hp-testimonial hp-testimonial--featured">
                                    <div class="hp-testimonial__stars">★★★★★</div>
                                    <p>"Instalaram o aquecimento solar e agora uso a piscina o ano todo. O serviço foi impecável, desde o
                                        orçamento até a entrega. Valeu cada centavo!"</p>
                                        <div class="hp-testimonial__author">
                                            <div class="hp-testimonial__avatar">RO</div>
                                            <div>
                                                <strong>Roberto Oliveira</strong>
                                                <span>Araxá, MG</span>
                                            </div>
                                        </div>
                                    </div>
                                    <div class="hp-testimonial">
                                        <div class="hp-testimonial__stars">★★★★★</div>
                                        <p>"Fiz a banheira de hidromassagem com eles. Atendimento excelente, preço justo e resultado perfeito.
                                            Minha família amou!"</p>
                                            <div class="hp-testimonial__author">
                                                <div class="hp-testimonial__avatar">CA</div>
                                                <div>
                                                    <strong>Cristiane Almeida</strong>
                                                    <span>Araxá, MG</span>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <!-- ===== DIFERENCIAIS ===== -->
                                <section class="hp-diff">
                                    <div class="hp-diff__inner">
                                        <div class="hp-diff__text">
                                            <span class="hp-section-tag">Por que a Hidropool?</span>
                                            <h2 class="hp-section-title">Qualidade e Confiança<br>que Você Merece</h2>
                                            <p>Somos especializados em piscinas de vinil e azulejo em Araxá há anos, com uma equipe treinada, preços
                                                competitivos e foco total na satisfação do cliente.</p>
                                                <div class="hp-diff__items">
                                                    <div class="hp-diff__item">
                                                        <span>🏆</span>
                                                        <div>
                                                            <strong>Alta Qualidade</strong>
                                                            <p>Materiais premium e execução impecável em cada projeto.</p>
                                                        </div>
                                                    </div>
                                                    <div class="hp-diff__item">
                                                        <span>💰</span>
                                                        <div>
                                                            <strong>Preço Justo</strong>
                                                            <p>Orçamento transparente, sem surpresas no final da obra.</p>
                                                        </div>
                                                    </div>
                                                    <div class="hp-diff__item">
                                                        <span>📐</span>
                                                        <div>
                                                            <strong>Projeto Incluso</strong>
                                                            <p>Planta técnica hidráulica e estrutural sem custo adicional.</p>
                                                        </div>
                                                    </div>
                                                    <div class="hp-diff__item">
                                                        <span>🤝</span>
                                                        <div>
                                                            <strong>Pós-Venda</strong>
                                                            <p>Suporte completo após a entrega para sua tranquilidade.</p>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="hp-diff__visual">
                                                <div class="hp-diff__pool-art">
                                                    <div class="hp-diff__pool-water"></div>
                                                    <div class="hp-diff__pool-lane hp-diff__pool-lane--1"></div>
                                                    <div class="hp-diff__pool-lane hp-diff__pool-lane--2"></div>
                                                    <div class="hp-diff__pool-lane hp-diff__pool-lane--3"></div>
                                                    <div class="hp-diff__pool-ripple"></div>
                                                </div>
                                                <div class="hp-diff__badge-float">
                                                    <span class="hp-diff__badge-icon">⭐</span>
                                                    <strong>4.9</strong>
                                                    <span>Avaliação Média</span>
                                                </div>
                                            </div>
                                        </div>
                                    </section>

                                    <!-- ===== FORMULÁRIO ===== -->
                                    <section class="hp-form-section" id="orcamento">
                                        <div class="hp-form-section__inner">
                                            <div class="hp-form-section__left">
                                                <span class="hp-section-tag hp-section-tag--light">Grátis & Sem Compromisso</span>
                                                <h2 class="hp-section-title hp-section-title--light">Solicite Seu<br>Orçamento Agora</h2>
                                                <p>Preencha os dados e nossa equipe entra em contato em até <strong>2 horas</strong> em dias úteis.</p>
                                                <div class="hp-form-section__contacts">
                                                    <a href="tel:+5534999999999" class="hp-contact-link">📞 (34) 3662-0202</a>
                                                    <a href="mailto:hidropoolaraxa@gmail.com" class="hp-contact-link">✉️ hidropoolaraxa@gmail.com</a>
                                                    <span class="hp-contact-link">📍 Rua Dr. Edmar Cunha, 329A – Araxá, MG</span>
                                                </div>
                                            </div>
                                            <div class="hp-form-section__right">
                                                <EditForm Model="@_formModel" OnValidSubmit="HandleSubmit" class="hp-form">
                                                    <DataAnnotationsValidator />
                                                    <div class="hp-form__row">
                                                        <div class="hp-form__field">
                                                            <label>Nome Completo *</label>
                                                            <InputText @bind-Value="_formModel.Nome" placeholder="Seu nome" class="hp-input" />
                                                            <ValidationMessage For="@(() => _formModel.Nome)" />
                                                        </div>
                                                        <div class="hp-form__field">
                                                            <label>Telefone / WhatsApp *</label>
                                                            <InputText @bind-Value="_formModel.Telefone" placeholder="(34) 9 9999-9999"
                                                                       class="hp-input" />
                                                            <ValidationMessage For="@(() => _formModel.Telefone)" />
                                                        </div>
                                                    </div>
                                                    <div class="hp-form__field">
                                                        <label>E-mail</label>
                                                        <InputText @bind-Value="_formModel.Email" placeholder="seu@email.com" class="hp-input" />
                                                    </div>
                                                    <div class="hp-form__field">
                                                        <label>Tipo de Serviço</label>
                                                        <InputSelect @bind-Value="_formModel.Servico" class="hp-input hp-select">
                                                            <option value="">Selecione...</option>
                                                            <option value="vinil">Piscina de Vinil</option>
                                                            <option value="azulejo">Piscina de Azulejo</option>
                                                            <option value="solar">Aquecimento Solar</option>
                                                            <option value="spa">Spa / Hidromassagem / Sauna</option>
                                                            <option value="manutencao">Manutenção</option>
                                                            <option value="outros">Outros</option>
                                                        </InputSelect>
                                                    </div>
                                                    <div class="hp-form__field">
                                                        <label>Mensagem</label>
                                                        <InputTextArea @bind-Value="_formModel.Mensagem" rows="4"
                                                                       placeholder="Conte um pouco sobre seu projeto (tamanho desejado, local, etc.)"
                                                                       class="hp-input hp-textarea" />
                                                    </div>
                                                    @if (_enviado)
                                                    {
                                                        <div class="hp-form__success">
                                                            🎉 Mensagem enviada! Entraremos em contato em breve.
                                                        </div>
                                                    }
                                                    else
                                                    {
                                                        <button type="submit" class="hp-btn hp-btn--primary hp-btn--full" disabled="@_enviando">
                                                            @(_enviando ? "Enviando..." : "Solicitar Orçamento Grátis 🚀")
                                                        </button>
                                                    }
                                                </EditForm>
                                            </div>
                                        </div>
                                    </section>

                                    <!-- ===== FOOTER ===== -->
                                    <footer class="hp-footer">
                                        <div class="hp-footer__inner">
                                            <div class="hp-footer__brand">
                                                <span class="hp-nav__logo-icon">🏊</span>
                                                <span class="hp-nav__logo-text">Hidropool <em>Araxá</em></span>
                                                <p>Especialistas em piscinas de vinil e azulejo.<br>Araxá, Minas Gerais.</p>
                                            </div>
                                            <div class="hp-footer__links">
                                                <strong>Links Rápidos</strong>
                                                <a href="#servicos">Serviços</a>
                                                <a href="#orcamento">Orçamento</a>
                                                <a href="https://wa.me/5534999999999" target="_blank">WhatsApp</a>
                                            </div>
                                            <div class="hp-footer__social">
                                                <strong>Redes Sociais</strong>
                                                <a href="https://www.instagram.com/hidropool_araxa/" target="_blank">📸 Instagram</a>
                                                <a href="https://www.facebook.com/hidropoolaraxa/" target="_blank">👤 Facebook</a>
                                            </div>
                                        </div>
                                        <div class="hp-footer__bottom">
                                            <p>© @DateTime.Now.Year Hidropool Araxá – Todos os direitos reservados.</p>
                                        </div>
                                    </footer>

                                </div>

                                <!-- ===== WHATSAPP FLOAT ===== -->
                                <a href="https://wa.me/5534999999999?text=Olá!%20Quero%20um%20orçamento%20de%20piscina." target="_blank"
                                   class="hp-whatsapp-float" title="Falar no WhatsApp">
                                    <svg viewBox="0 0 24 24" fill="currentColor" width="28" height="28">
                                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15
                                        -.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075
                                        -.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059
                                        -.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52
                                        .149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52
                                        -.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51
                                        -.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372
                                        -.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074
                                        .149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625
                                        .712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413
