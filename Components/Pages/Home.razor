                                        <path
                                        d="M11.99 2C6.477 2 2 6.484 2 12.017c0 1.99.522 3.86 1.438 5.475L2 22l4.637-1.215
                                        A9.953 9.953 0 0011.99 22C17.515 22 22 17.516 22 11.983 22 6.451 17.515 2 11.99 2z" />
                                    </svg>
