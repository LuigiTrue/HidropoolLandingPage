@code {
    private FormModel _formModel = new();
    private bool _enviando = false;
    private bool _enviado = false;

    private async Task HandleSubmit()
    {
        _enviando = true;
        await Task.Delay(1500); // Simula chamada de API
        _enviado = true;
        _enviando = false;
        _formModel = new();
    }

    public class FormModel
    {
        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Nome obrigatório")]
        public string Nome { get; set; } = string.Empty;

        [System.ComponentModel.DataAnnotations.Required(ErrorMessage = "Telefone obrigatório")]
        public string Telefone { get; set; } = string.Empty;

        public string Email { get; set; } = string.Empty;
        public string Servico { get; set; } = string.Empty;
        public string Mensagem { get; set; } = string.Empty;
    }
}


